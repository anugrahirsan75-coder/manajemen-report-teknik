# Salin ke .env.local (lokal) atau isi di Vercel Environment Variables.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# PDF: di cloud WAJIB matikan (MS Office hanya ada di PC lokal)
DISABLE_OFFICE_PDF=1
NEXT_PUBLIC_ENABLE_PDF=false

# Login app — daftar "user:password" dipisah koma
APP_USERS=admin:gantipassword,teknik:gantipassword
# token sesi rahasia (acak panjang), mis: openssl rand -hex 24
AUTH_TOKEN=ganti_dengan_string_acak_panjang

# opsional: override URL CSV DB material (default endpoint gviz)
# MATERIAL_DB_CSV_URL=
